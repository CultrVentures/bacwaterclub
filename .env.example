# ──────────────────────────────────────────────────────────────────────────
# Bacwaterclub.com — environment variables
# Copy this file to .env.local and fill in real values for local development.
# In production, set these via your hosting platform's secret manager.
# ──────────────────────────────────────────────────────────────────────────

# Public URL the app is served from. Used by the Stripe Checkout success/cancel
# redirects and the Xero OAuth callback. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────
# Stripe — checkout
# ──────────────────────────────────────────────────────────────────────────

# Stripe secret key (sk_test_... in dev, sk_live_... in prod).
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe webhook signing secret. Created when you register the webhook
# endpoint in the Stripe dashboard, or printed by `stripe listen` for local
# development. Required for the /api/webhooks/stripe handler to verify
# incoming events. The webhook becomes a no-op until this is set.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# ──────────────────────────────────────────────────────────────────────────
# Xero — accounting integration
# Used by /api/xero/connect, /api/xero/callback, and the Stripe webhook
# dispatcher to push Contact + Invoice + Payment records to Xero on every
# successful checkout. The integration is a no-op until both XERO_CLIENT_ID
# and XERO_CLIENT_SECRET are set.
# ──────────────────────────────────────────────────────────────────────────

# OAuth2 client credentials from developer.xero.com → My Apps.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Must exactly match a redirect URI registered on the Xero app.
# For local dev with Next.js on port 3000:
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# Xero account codes used when creating invoices and payments.
# Find these in your Xero org under Accounting → Chart of accounts.
#   - SALES code: revenue account for product sales (commonly 200 "Sales")
#   - PAYMENT code: bank account that represents Stripe in Xero
#     (create one called "Stripe" if you don't already have one — code 090
#      is a common convention)
XERO_SALES_ACCOUNT_CODE=200
XERO_PAYMENT_ACCOUNT_CODE=090

# Optional: lock the integration to a single Xero organisation. After you
# complete the OAuth flow once, the callback handler will print the
# tenant ID — paste it here to ensure subsequent webhook deliveries always
# write to this organisation. Leave blank during initial setup.
XERO_TENANT_ID=
